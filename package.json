{
  "name": "familia-maestre",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" && start http://localhost:3000",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "build": "npm run build --workspace=apps/backend && npm run build --workspace=apps/frontend",
    "test": "npm run test --workspace=apps/backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace=apps/backend",
    "db:seed": "npm run prisma:seed --workspace=apps/backend",
    "db:studio": "npm run prisma:studio --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "multer": "^2.2.0",
    "@nestjs/platform-express": {
      "multer": "^2.2.0"
    },
    "postcss": "^8.5.15"
  }
}
