// ============================================================
// schema.prisma — Sistema de Administração Familiar
// Versão: 1.0 | Fase 1 — Especificação
// Banco: PostgreSQL | ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ShoppingItemStatus {
  PENDING
  PURCHASED
  CANCELLED
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum PaymentMethod {
  PIX
  CASH
  DEBIT_CARD
  CREDIT_CARD
}

enum EventType {
  MEDICAL
  SCHOOL
  ROUTINE
  APPOINTMENT
  OTHER
}

enum EventStatus {
  SCHEDULED
  CONFIRMED
  DONE
  CANCELLED
  RESCHEDULED
}

enum NotificationType {
  SHOPPING_ITEM_ADDED
  PAYMENT_DUE
  EVENT_REMINDER
  REPORT_READY
  CONFIRMATION_REQUEST
  GENERAL
}

enum ReportType {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ReportStatus {
  GENERATING
  READY
  SENT
  FAILED
}

enum FiscalReceiptStatus {
  SCANNED
  PROCESSING
  REVIEWED
  IMPORTED
  ERROR
}

enum AiProvider {
  OPENAI
}

// ============================================================
// USUÁRIOS
// ============================================================

model User {
  id             String    @id @default(cuid())
  name         String
  phone        String    @unique
  passwordHash String
  role           Role      @default(MEMBER)
  avatarUrl      String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shoppingRequests  ShoppingItem[]   @relation("RequestedBy")
  shoppingPurchases ShoppingItem[]   @relation("PurchasedBy")
  transactions      Transaction[]
  eventAttendees    EventAttendee[]
  notifications     Notification[]
  aiLogs            AiLog[]

  @@map("users")
}

// ============================================================
// LISTA DE SUPERMERCADO
// ============================================================

model ShoppingList {
  id        String    @id @default(cuid())
  name      String    @default("Lista principal")
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items ShoppingItem[]

  @@map("shopping_lists")
}

model ShoppingItem {
  id              String             @id @default(cuid())
  name            String
  quantity        Float              @default(1)
  unit            String?
  category        String?
  priority        Priority           @default(MEDIUM)
  status          ShoppingItemStatus @default(PENDING)
  notes           String?
  originalMessage String?
  aiExtracted     Boolean            @default(false)
  estimatedPrice  Decimal?           @db.Decimal(10, 2)
  purchasedPrice  Decimal?           @db.Decimal(10, 2)
  purchasedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  listId          String
  list            ShoppingList   @relation(fields: [listId], references: [id])
  requestedById   String
  requestedBy     User           @relation("RequestedBy", fields: [requestedById], references: [id])
  purchasedById   String?
  purchasedBy     User?          @relation("PurchasedBy", fields: [purchasedById], references: [id])
  transaction     Transaction?

  @@index([listId, status])
  @@index([requestedById])
  @@map("shopping_items")
}

// ============================================================
// COMPRAS / CUPONS FISCAIS
// ============================================================

model Product {
  id               String    @id @default(cuid())
  name             String    @unique
  normalizedName   String?
  brand            String?
  category         String?
  variant          String?
  lastUnitPrice    Decimal?  @db.Decimal(10, 2)
  unit             String?
  taxes            Decimal?  @db.Decimal(10, 2)
  lastPurchasedAt  DateTime?
  lastSupplierName String?
  lastReceiptId    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  historyItems PurchaseHistoryItem[]

  @@index([brand])
  @@index([category])
  @@map("products")
}

model FiscalReceipt {
  id             String              @id @default(cuid())
  qrCodeRaw      String?
  url            String?
  accessKey      String?             @unique
  supplierName   String?
  tradeName      String?
  documentNumber String?
  purchaseDate   DateTime
  totalAmount    Decimal             @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  cardLast4      String?
  status         FiscalReceiptStatus @default(SCANNED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  items       PurchaseHistoryItem[]
  transaction Transaction?

  @@index([purchaseDate])
  @@index([documentNumber])
  @@map("fiscal_receipts")
}

model PurchaseHistoryItem {
  id            String         @id @default(cuid())
  productName   String
  unitPrice     Decimal        @db.Decimal(10, 2)
  unit          String?
  taxes         Decimal?       @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  accessKey     String?
  discount      Decimal?       @db.Decimal(10, 2)
  quantity      Float          @default(1)
  purchaseDate  DateTime
  cardLast4     String?
  totalAmount   Decimal        @db.Decimal(10, 2)
  createdAt     DateTime       @default(now())

  productId String?
  product   Product?      @relation(fields: [productId], references: [id])
  receiptId String
  receipt   FiscalReceipt @relation(fields: [receiptId], references: [id])

  @@index([productName, purchaseDate])
  @@index([receiptId])
  @@map("purchase_history_items")
}

// ============================================================
// FINANCEIRO
// ============================================================

model TransactionCategory {
  id        String          @id @default(cuid())
  name      String          @unique
  type      TransactionType
  color     String?
  deletedAt DateTime?
  createdAt DateTime        @default(now())

  transactions Transaction[]

  @@map("transaction_categories")
}

model Transaction {
  id           String          @id @default(cuid())
  description  String
  supplierName String?
  tradeName String?
  documentNumber String?
  paymentMethod PaymentMethod?
  amount       Decimal         @db.Decimal(10, 2)
  type         TransactionType
  dueDate      DateTime?
  paidAt       DateTime?
  isPaid       Boolean         @default(false)
  isRecurring  Boolean         @default(false)
  recurringDay Int?
  notes        String?
  receiptUrl   String?
  aiExtracted  Boolean         @default(false)
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  categoryId     String?
  category       TransactionCategory? @relation(fields: [categoryId], references: [id])
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  shoppingItemId String?              @unique
  shoppingItem   ShoppingItem?        @relation(fields: [shoppingItemId], references: [id])
  fiscalReceiptId String?             @unique
  fiscalReceipt   FiscalReceipt?      @relation(fields: [fiscalReceiptId], references: [id])

  @@index([userId, type])
  @@index([dueDate, isPaid])
  @@map("transactions")
}

// ============================================================
// AGENDAMENTOS
// ============================================================

model Event {
  id            String      @id @default(cuid())
  title         String
  type          EventType
  status        EventStatus @default(SCHEDULED)
  description   String?
  location      String?
  startsAt      DateTime
  endsAt        DateTime?
  isRecurring   Boolean     @default(false)
  recurringRule String?
  documentUrl   String?
  aiExtracted   Boolean     @default(false)
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  attendees EventAttendee[]

  @@index([startsAt, status])
  @@map("events")
}

model EventAttendee {
  id          String    @id @default(cuid())
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ============================================================
// NOTIFICAÇÕES
// ============================================================

model Notification {
  id                String           @id @default(cuid())
  type              NotificationType
  title             String
  message           String
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, sentAt])
  @@map("notifications")
}

// ============================================================
// RELATÓRIOS
// ============================================================

model Report {
  id        String       @id @default(cuid())
  type      ReportType
  status    ReportStatus @default(GENERATING)
  period    String
  fileUrl   String?
  sentAt    DateTime?
  payload   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([type, status])
  @@map("reports")
}

// ============================================================
// LOGS DE IA
// ============================================================

model AiLog {
  id               String     @id @default(cuid())
  provider         AiProvider @default(OPENAI)
  model            String
  module           String
  operation        String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal    @db.Decimal(10, 6)
  latencyMs        Int
  success          Boolean
  errorMessage     String?
  inputSummary     String?
  outputSummary    String?
  createdAt        DateTime   @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([module, createdAt])
  @@index([userId])
  @@map("ai_logs")
}
