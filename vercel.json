{
  "buildCommand": "npm run build --workspace=apps/frontend",
  "outputDirectory": "apps/frontend/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://familia-maestre-backend.up.railway.app/api/:path*"
    }
  ]
}
