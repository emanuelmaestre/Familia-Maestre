# ============================================================
# Banco de Dados
# ============================================================
POSTGRES_USER=familia
POSTGRES_PASSWORD=familia123
POSTGRES_DB=familia_db
DATABASE_URL="postgresql://familia:familia123@localhost:5432/familia_db"
REDIS_URL="redis://localhost:6379"

# ============================================================
# Auth
# ============================================================
JWT_SECRET="troque-por-uma-chave-secreta-forte-min-32-chars"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="troque-por-outra-chave-secreta-forte"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================================
# Telegram
# ============================================================
TELEGRAM_BOT_TOKEN="SEU_TOKEN_DO_BOTFATHER_AQUI"
